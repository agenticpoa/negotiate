# ── Required ──────────────────────────────────────────────

ANTHROPIC_API_KEY=your-api-key-here

# ── Your role ─────────────────────────────────────────────
# Leave blank to run both agents on one machine (demo/testing)
# Set to "founder" or "investor" for separate machines

ROLE=

# ── Negotiation ID ────────────────────────────────────────
# Same machine: leave blank (auto-generated)
# Separate machines, founder: leave blank (one will be generated for you)
# Separate machines, investor: paste the ID the founder gives you

NEGOTIATION_ID=

# ── Party names ───────────────────────────────────────────

COMPANY_NAME=Acme Labs
FOUNDER_NAME=Alice Chen
FOUNDER_TITLE=CEO
INVESTOR_NAME=Jordan Lee
INVESTOR_FIRM=Bay Capital

# ══════════════════════════════════════════════════════════
# FOUNDER SETTINGS (only matters if you are the founder)
# ══════════════════════════════════════════════════════════

# What your agent is allowed to negotiate and sign:
#   Negotiation: enforced by your APOA token (github.com/agenticpoa/apoa)
#   Signing: enforced by your signing key on sshsign (sshsign.dev)
FOUNDER_CAP_MIN=8000000
FOUNDER_CAP_MAX=12000000
FOUNDER_DISCOUNT_MIN=0.20
FOUNDER_DISCOUNT_MAX=0.25
FOUNDER_PRO_RATA_REQUIRED=true
FOUNDER_MFN_REQUIRED=false

# Require handwritten signature for the founder?
FOUNDER_REQUIRE_SIGNATURE=true

# Existing signing key (leave blank to create one automatically)
FOUNDER_SIGNING_KEY_ID=

# ══════════════════════════════════════════════════════════
# INVESTOR SETTINGS (only matters if you are the investor)
# ══════════════════════════════════════════════════════════

# What your agent is allowed to negotiate and sign:
#   Negotiation: enforced by your APOA token (github.com/agenticpoa/apoa)
#   Signing: enforced by your signing key on sshsign (sshsign.dev)
INVESTOR_CAP_MIN=6000000
INVESTOR_CAP_MAX=10000000
INVESTOR_DISCOUNT_MIN=0.15
INVESTOR_DISCOUNT_MAX=0.25
INVESTOR_PRO_RATA_REQUIRED=false
INVESTOR_MFN_REQUIRED=false

# Require handwritten signature for the investor?
INVESTOR_REQUIRE_SIGNATURE=true

# Existing signing key (leave blank to create one automatically)
INVESTOR_SIGNING_KEY_ID=
